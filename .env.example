# Configuración de Supabase para La Jungla CRM
# Copia este archivo a .env y completa con tus credenciales reales

# URL de tu proyecto Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública anónima de Supabase
VITE_SUPABASE_ANON_KEY=tu_clave_anonima_aqui

# Clave de servicio (solo para scripts de administración)
SUPABASE_SERVICE_ROLE_KEY=tu_clave_de_servicio_aqui

# Configuración adicional
NODE_ENV=development

# API Key de Google Gemini para generación de actas
# Obtener en: https://aistudio.google.com/app/apikey
VITE_GOOGLE_API_KEY=tu_api_key_de_google_aqui
GOOGLE_API_KEY=tu_api_key_de_google_aqui

# Facebook / Instagram Integration
VITE_FACEBOOK_APP_ID=tu_app_id_de_facebook_aqui

# ── Wodbuster Integration ────────────────────────────────────────────────────
# Usuario Basic Auth para los 3 centros (mismo para todos)
WODBUSTER_USERNAME=lajunglaworkout

# Contraseñas Basic Auth por centro (Wodbuster → Configuración → API)
WODBUSTER_PASSWORD_SEVILLA=tu_password_centro_workout
WODBUSTER_PASSWORD_JEREZ=tu_password_centro_jerez
WODBUSTER_PASSWORD_PUERTO=tu_password_centro_puerto

# API Keys del RestHook por centro (Wodbuster → Configuración → API → RestHook)
# Validan webhooks entrantes Y se prueban como auth alternativa en el sync diario
WODBUSTER_APIKEY_SEVILLA=valor_de_wodbuster
WODBUSTER_APIKEY_JEREZ=valor_de_wodbuster
WODBUSTER_APIKEY_PUERTO=valor_de_wodbuster

# IMPORTANTE: Las variables WODBUSTER_* deben configurarse también en:
# Netlify Dashboard → Site configuration → Environment variables
